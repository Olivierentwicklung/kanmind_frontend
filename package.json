{
  "name": "kanmind-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nx serve kanmind",
    "serve": "nx serve kanmind",
    "serve:legacy": "nx run kanmind-legacy:serve",
    "build": "nx build kanmind",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "test:e2e": "nx e2e kanmind-e2e",
    "test:e2e:headed": "nx e2e kanmind-e2e --headed",
    "test:e2e:ui": "playwright test -c apps/kanmind-e2e/playwright.config.mts --ui",
    "test:e2e:report": "playwright show-report playwright-report/angular",
    "test:legacy:e2e": "nx e2e kanmind-legacy-e2e",
    "test:legacy:e2e:headed": "nx e2e kanmind-legacy-e2e --headed",
    "test:legacy:e2e:ui": "playwright test -c apps/kanmind-legacy-e2e/playwright.config.js --ui",
    "test:legacy:e2e:report": "playwright show-report playwright-report/legacy",
    "affected": "nx affected -t lint,test,build --base=main"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~2.6.0",
    "@analogjs/vitest-angular": "~2.6.0",
    "@angular-devkit/core": "~22.0.4",
    "@angular-devkit/schematics": "~22.0.4",
    "@angular/build": "~22.0.4",
    "@angular/cli": "~22.0.4",
    "@angular/compiler-cli": "~22.0.4",
    "@angular/language-service": "~22.0.4",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^23.1.0",
    "@nx/devkit": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "^23.1.0",
    "@nx/web": "23.1.0",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "~22.0.4",
    "@swc/helpers": "~0.5.18",
    "@types/node": "^22.0.0",
    "@typescript-eslint/utils": "^8.58.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "http-server": "^14.1.1",
    "jsdom": "^27.1.0",
    "nx": "23.1.0",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.8"
  },
  "nx": {},
  "dependencies": {
    "@angular/common": "~22.0.4",
    "@angular/compiler": "~22.0.4",
    "@angular/core": "~22.0.4",
    "@angular/forms": "~22.0.4",
    "@angular/platform-browser": "~22.0.4",
    "@angular/router": "~22.0.4",
    "@ngrx/signals": "^22.0.0-beta.0",
    "rxjs": "~7.8.0"
  }
}
